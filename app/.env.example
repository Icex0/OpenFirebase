# ---------- Backend (full-privilege) ----------
APP_SECRET=change-me-to-a-long-random-string
DATABASE_URL=postgresql+asyncpg://openfirebase:openfirebase@postgres:5432/openfirebase
CORS_ORIGINS=http://localhost:8080

# MinIO root credentials — used by the backend for uploads and by the
# one-shot minio-init container to bootstrap the scoped scanner user.
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=openfirebase
S3_SECRET_KEY=openfirebase-secret
S3_BUCKET=openfirebase-apks
S3_REGION=us-east-1

# ---------- Postgres superuser ----------
POSTGRES_USER=openfirebase
POSTGRES_PASSWORD=openfirebase
POSTGRES_DB=openfirebase

# ---------- Scanner sandbox (scoped credentials) ----------
# The scanner worker runs in an isolated container and must not hold any
# credential that would let it touch the user table, drop DB objects, or
# read other users' bundles. These scoped secrets are the only creds it
# ever sees. The defaults below work out of the box for local dev — rotate
# (independently of the backend creds above) before deploying.
# NOTE: SCANNER_DB_PASSWORD must match the password embedded in
# SCANNER_DATABASE_URL; change both together.
SCANNER_DB_PASSWORD=scanner-dev-password
SCANNER_DATABASE_URL=postgresql+asyncpg://scanner_user:scanner-dev-password@postgres:5432/openfirebase
SCANNER_S3_ACCESS_KEY=scanner
SCANNER_S3_SECRET_KEY=scanner-dev-secret

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost:8000
