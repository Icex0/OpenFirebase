{$CADDY_DOMAIN::80} {
	encode zstd gzip

	# Backend API. handle_path strips /api before forwarding, so FastAPI
	# keeps seeing its native routes (/auth, /scans, /storage, /health).
	# flush_interval -1 disables response buffering so SSE (/scans/*/stream)
	# delivers events in real time.
	handle_path /api/* {
		reverse_proxy backend:8000 {
			flush_interval -1
		}
	}

	# SPA / Vite dev server.
	handle {
		reverse_proxy frontend:8080
	}
}
